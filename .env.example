# Server configuration
PORT=5000
MONGODB_URI=mongodb://localhost:27017/cell_xchange
JWT_SECRET=super_secret_jwt_signkey_for_cell_xchange_12345

# Cloudflare R2 Config (S3-compatible)
# If left blank, the server will fallback to saving uploads to the local filesystem (uploads/ directory)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Fallback Local Storage settings
LOCAL_UPLOAD_DIR=uploads
